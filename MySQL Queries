Keys :
1. Primary Key : To make a column unique
2. Foreign Key : It is used to link one table to another 

How to create Primary Key?
create table tableName(colName data type (size) Primary Key, colName2 datatype(size),.... );


How to create foreign Key 

create table tableName(colName data type(size), ....., foreign Key fname reference tableName (colName))

create TABLE dept (did int PRIMARY KEY, dname varchar(44))


INSERT INTO dept(did, dname)
VALUES(1,'HR'),
(2,'Sales'),
(3,'IT'),
(4,'Marketing');

create TABLE emp(eid int PRIMARY key AUTO_INCREMENT, ename varchar(33), d_id int , FOREIGN KEY (d_id) REFERENCES dept(did));

